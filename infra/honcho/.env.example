# Copy to infra/honcho/.env
# This stack runs a dedicated Compose-owned PostgreSQL + pgvector instance for Honcho.

HONCHO_DB_NAME=honcho
HONCHO_DB_USER=honcho_app
HONCHO_DB_PASSWORD=replace-me
AUTH_USE_AUTH=false
DB_SCHEMA=public
HERMES_AUTH_PATH=$HOME/.hermes/auth.json
HERMES_AUTH_LOCK_PATH=$HOME/.hermes/auth.lock
CODEX_AUTH_PATH=$HOME/.codex/auth.json

# Override these if the host user that owns the mounted auth files is not 1000:1000.
HOST_UID=1000
HOST_GID=1000

# Shared local bridge auth between Honcho and codex-bridge.
CODEX_BRIDGE_API_KEY=change-me-local-bridge-key
LLM_OPENAI_COMPATIBLE_BASE_URL=http://codex-bridge:8001/v1
LLM_OPENAI_COMPATIBLE_API_KEY=${CODEX_BRIDGE_API_KEY}
LLM_EMBEDDING_PROVIDER=openrouter

DERIVER_PROVIDER=custom
DERIVER_MODEL=gpt-5.4-mini
SUMMARY_PROVIDER=custom
SUMMARY_MODEL=gpt-5.4-mini
DREAM_PROVIDER=custom
DREAM_MODEL=gpt-5.4-mini
DREAM_DEDUCTION_MODEL=gpt-5.4-mini
DREAM_INDUCTION_MODEL=gpt-5.4-mini

DIALECTIC_LEVELS__minimal__PROVIDER=custom
DIALECTIC_LEVELS__minimal__MODEL=gpt-5.4-mini
DIALECTIC_LEVELS__minimal__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__minimal__MAX_TOOL_ITERATIONS=1
DIALECTIC_LEVELS__low__PROVIDER=custom
DIALECTIC_LEVELS__low__MODEL=gpt-5.4-mini
DIALECTIC_LEVELS__low__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__low__MAX_TOOL_ITERATIONS=5
DIALECTIC_LEVELS__medium__PROVIDER=custom
DIALECTIC_LEVELS__medium__MODEL=gpt-5.4-mini
DIALECTIC_LEVELS__medium__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__medium__MAX_TOOL_ITERATIONS=2
DIALECTIC_LEVELS__high__PROVIDER=custom
DIALECTIC_LEVELS__high__MODEL=gpt-5.4-mini
DIALECTIC_LEVELS__high__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__high__MAX_TOOL_ITERATIONS=4
DIALECTIC_LEVELS__max__PROVIDER=custom
DIALECTIC_LEVELS__max__MODEL=gpt-5.4-mini
DIALECTIC_LEVELS__max__THINKING_BUDGET_TOKENS=0
DIALECTIC_LEVELS__max__MAX_TOOL_ITERATIONS=10
