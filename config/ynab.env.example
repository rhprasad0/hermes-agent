# Local-only example. Do not commit a real token.
# If more than one YNAB plan is visible to the token, replace `default`
# with the specific plan id you want Hermes to use.
YNAB_ACCESS_TOKEN=YOUR_YNAB_PERSONAL_ACCESS_TOKEN_HERE
YNAB_PLAN_ID=default
YNAB_BASE_URL=https://api.ynab.com/v1
YNAB_TIMEOUT=30
